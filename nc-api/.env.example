# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────
# WHATSAPP_TOKEN and WHATSAPP_PHONE_NUMBER_ID have been removed.
# Set these per-business in businesses/<id>.json:
#   "whatsapp_token": "EAAx..."
#   "whatsapp_phone_number_id": "123456789"
WHATSAPP_VERIFY_TOKEN="tu_token_secreto_de_verificacion"
WHATSAPP_API_VERSION="v22.0"

# ── Groq API ─────────────────────────────────────────────────────────────
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama3-70b-8192"
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.7

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver)
# Railway PostgreSQL plugin auto-injects this.
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL="postgresql+asyncpg://postgres:1234@localhost:5432/nuncacierro"

# ── Evolution API (opcional) ──────────────────────────────────────────────
# Evolution API v2.x es una pasarela WhatsApp auto-hospedada.
# La configuracion (base_url, api_key, instance_name) se guarda por conexion
# en PlatformConnection.credentials (cifrado), no aca.
# Ejemplo de credentials para una conexion Evolution:
#
#   POST /api/v1/platform-connections
#   {
#     "tenant_id": "...",
#     "platform_type": "evolution",
#     "display_name": "WhatsApp Evolution",
#     "credentials": {
#       "base_url": "https://evolution-api-production-9fb2.up.railway.app",
#       "api_key": "tu-api-key",
#       "instance_name": "nuncacierro"
#     }
#   }

# ── App ──────────────────────────────────────────────────────────────────
APP_PORT=8000
APP_HOST="0.0.0.0"
LOG_LEVEL="INFO"
