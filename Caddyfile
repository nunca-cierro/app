# ── Caddyfile ──────────────────────────────────────────────────────────
# SSL automático con Let's Encrypt.
# Variables de entorno: CADDY_DOMAIN (ej: nuncacierro.com)
#
# Estructura:
#   {domain}      → Dashboard (Next.js) — landing y app
#   api.{domain}  → API (FastAPI)
#
# DNS requerido:
#   {domain}      → A / AAAA al server
#   api.{domain}  → A / AAAA al server
# ───────────────────────────────────────────────────────────────────────

{$CADDY_DOMAIN:localhost} {
    reverse_proxy nc-dashboard:3000
}

api.{$CADDY_DOMAIN:localhost} {
    reverse_proxy nc-api:8000
}
